{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CapNav-Lite user profile",
  "type": "object",
  "required": [
    "profile_version",
    "user_id",
    "created_utc",
    "capability",
    "confidence",
    "safety_limits"
  ],
  "properties": {
    "profile_version": {
      "type": "string",
      "const": "0.1"
    },
    "user_id": {
      "type": "string",
      "description": "Opaque identifier, not a real name."
    },
    "created_utc": {
      "type": "string",
      "description": "ISO 8601 UTC timestamp."
    },
    "capability": {
      "type": "object",
      "required": [
        "turning_cost",
        "backtracking_cost",
        "slip"
      ],
      "properties": {
        "turning_cost": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "backtracking_cost": {
          "type": "number",
          "minimum": 0,
          "maximum": 10
        },
        "slip": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      },
      "additionalProperties": false
    },
    "confidence": {
      "type": "object",
      "required": [
        "turning_cost_ci95",
        "backtracking_cost_ci95",
        "slip_ci95",
        "n_episodes"
      ],
      "properties": {
        "turning_cost_ci95": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "backtracking_cost_ci95": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "slip_ci95": {
          "type": "array",
          "items": {
            "type": "number"
          },
          "minItems": 2,
          "maxItems": 2
        },
        "n_episodes": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "safety_limits": {
      "type": "object",
      "required": [
        "max_omega_rad_s",
        "max_v_m_s",
        "max_turns_per_meter",
        "min_clearance_m",
        "fallback_policy"
      ],
      "properties": {
        "max_omega_rad_s": {
          "type": "number",
          "minimum": 0
        },
        "max_v_m_s": {
          "type": "number",
          "minimum": 0
        },
        "max_turns_per_meter": {
          "type": "number",
          "minimum": 0
        },
        "min_clearance_m": {
          "type": "number",
          "minimum": 0
        },
        "fallback_policy": {
          "type": "string",
          "enum": [
            "shared_control",
            "stop_and_alert"
          ]
        }
      },
      "additionalProperties": false
    },
    "notes": {
      "type": "string"
    }
  },
  "additionalProperties": false
}